{
  "extends": [
    "next/core-web-vitals"
  ],
  "plugins": [
    "@typescript-eslint"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "args": "all"
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "*.js",
        "*.mjs"
      ],
      "parser": "espree",
      "parserOptions": {
        "ecmaVersion": "latest"
      }
    }
  ],
  "env": {
    "browser": true,
    "es6": true
  }
}